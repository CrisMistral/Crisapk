{
  "name": "video-auto-publish-bot",
  "version": "1.0.0",
  "description": "Auto-publish videos to TikTok, Instagram and YouTube via Playwright bots",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
