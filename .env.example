# Copia este archivo a .env y rellena tus valores
# NUNCA subas el archivo .env a git
# En Netlify: Site configuration → Environment variables

# ── Stripe (pagos) ──────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# https://dashboard.stripe.com/webhooks (usa sk_test_... para pruebas)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email de aviso por cada pedido (opcional pero recomendado) ──
# Crea una cuenta gratis en https://resend.com y copia tu API key
RESEND_API_KEY=re_...
# Tu correo, donde quieres recibir el aviso de cada pedido
ORDER_EMAIL=tucorreo@ejemplo.com
# (Opcional) Remitente verificado en Resend. Si lo dejas vacío se usa
# el remitente de pruebas onboarding@resend.dev
FROM_EMAIL=What Maria Paints <onboarding@resend.dev>

# ── General ─────────────────────────────────────────────────────
# URL de tu web (Netlify la pone automáticamente)
URL=https://your-site.netlify.app
