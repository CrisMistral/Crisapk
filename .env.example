# ── VideoBot — Publicador automático ────────────────────────────────────────
# Copia este archivo como .env  →  cp .env.example .env
# NUNCA subas .env a git (ya está en .gitignore)

# Puerto del servidor Express (default: 3001)
PORT=3001

# true  = Playwright corre invisible (recomendado en VPS/servidor)
# false = Playwright abre ventana visible (útil para depurar)
HEADLESS=true

NODE_ENV=production
