# ── VideoBot SaaS — Variables de entorno ────────────────────────────────────
# Copia como .env  →  cp .env.example .env
# NUNCA subas .env a git

# Puerto (Railway lo pone automáticamente)
PORT=3001

# Clave secreta para JWT — pon cualquier string largo y aleatorio
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo_123

# ── YouTube (Google Cloud Console) ──────────────────────────────────────────
# https://console.cloud.google.com → APIs → YouTube Data API v3 → Credenciales
YOUTUBE_CLIENT_ID=xxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxx
# Para desarrollo local:
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/connect/youtube/callback
# Para producción (Railway):
# YOUTUBE_REDIRECT_URI=https://tu-app.railway.app/api/connect/youtube/callback

# ── Stripe (pagos) ──────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# IDs de precios (crear en Stripe Dashboard → Productos)
STRIPE_PRICE_STARTER=price_xxxx
STRIPE_PRICE_AGENCY=price_xxxx

# URL pública de la app (para Stripe redirects)
APP_URL=https://tu-app.railway.app

# Playwright en background (true en servidor, false para debug)
HEADLESS=true
NODE_ENV=production
